DATABASE_URL=postgres://postgres:postgres@localhost:5432/atra_dev
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-chars
PORT=3001

# Token / nonce lifetimes (all optional — defaults shown)
ACCESS_TOKEN_TTL=15m        # jsonwebtoken duration string
REFRESH_TOKEN_TTL_DAYS=30   # integer days
NONCE_TTL_MINUTES=5         # integer minutes
